---
import Layout from "@layouts/Layout.astro";
import Waves from "@components/Waves.astro";
import Nav from "@components/Nav.astro";
import Hero from "@components/Hero.astro";
import Projects from "@components/Projects.astro";
import Process from "@components/Process.astro";
import Contact from "@components/Contact.astro";
import Testimonials from "@components/Testimonials.astro";
import Footer from "@components/Footer.astro";

import es from "@i18n/es.json";
import en from "@i18n/en.json";
import it from "@i18n/it.json";
import { safeT } from "@i18n/safe-t";

export async function getStaticPaths() {
  const langs = ["es", "en", "it"];
  return langs.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: string };
const translations = { es, en, it };
const raw = translations[lang as keyof typeof translations];
if (!raw) return Astro.redirect("/es/");
const t = safeT(raw);
---

<Layout title={t.layout.title} description={t.layout.description} jobTitle={t.layout.jobTitle} lang={lang} t={t.layout}>
  <Waves />
  <Nav slot="nav" lang={lang} t={t.nav} />
  <Hero slot="hero" t={t.hero} />
  <Projects t={t.projects} />
  <Testimonials t={t.testimonials} />
  <Process t={t.process} />
  <Contact t={t.contact} />
  <Footer slot="footer" t={t.footer} lang={lang} />
</Layout>