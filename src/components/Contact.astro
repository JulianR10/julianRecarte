---
const links = [
  {
    label: "WhatsApp",
    href: "https://wa.me/393447817557",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>`,
  },
  {
    label: "Instagram",
    href: "https://instagram.com",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>`,
  },
  {
    label: "Email",
    href: "mailto:julianrecarteweb@gmail.com",
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 6L12 13 2 6M4 4h16a2 2 0 012 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2z"/></svg>`,
  },
];
---

<section
  id="contacto"
  class="flex items-center px-6 pt-32 pb-0 relative overflow-hidden"
>
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-accent-orange/[0.03] blur-3xl pointer-events-none"
  >
  </div>

  <div class="max-w-5xl mx-auto w-full relative px-6">
    <div class="text-center" data-reveal>
      <span
        class="inline-block text-xs font-medium tracking-[0.3em] uppercase text-accent-orange mb-6"
      >
        Contacto
      </span>

      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-12"
      >
        Trabajemos
        <br />
        <span class="text-accent-orange">juntos</span>
      </h2>

      <p
        class="text-lg md:text-xl text-copy/60 max-w-xl mx-auto leading-relaxed mb-10"
      >
        ¿Tenés un proyecto en mente? Estoy abierto a nuevas
        oportunidades y colaboraciones. Hablemos.
      </p>

      <a
        href="mailto:julianrecarteweb@gmail.com"
        class="inline-flex items-center gap-3 text-2xl md:text-3xl font-bold font-clash text-accent-purple hover:text-accent-purple/80 transition-colors duration-300 group"
      >
        <span>julianrecarteweb@gmail.com</span>
        <span
          class="inline-block transition-transform duration-300 group-hover:translate-x-2"
        >
          →
        </span>
      </a>
    </div>

    <div
      class="flex flex-wrap justify-center gap-4 md:gap-8 pt-12"
      data-reveal
      data-reveal-delay="0.3"
    >
      {links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 px-6 py-3 rounded-full border border-black/10 text-copy/60 hover:text-accent-orange hover:border-accent-orange/30 hover:bg-accent-orange/5 transition-all duration-300 text-sm font-medium"
        >
          <span set:html={link.icon} />
          {link.label}
        </a>
      ))}
    </div>
  </div>
</section>
