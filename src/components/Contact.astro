---
interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<section
  id="contacto"
  class="flex items-center px-6 pt-32 pb-0 relative overflow-hidden"
>
  <div
    class="absolute left-1/2 bottom-0 -translate-x-1/2 translate-y-1/2 w-[600px] h-[600px] rounded-full bg-accent-orange/[0.03] blur-3xl pointer-events-none dark:opacity-0"
  >
  </div>

  <div class="max-w-5xl mx-auto w-full relative px-6">
    <div class="text-center" data-reveal>
      <span
        class="inline-block text-xs font-medium tracking-[0.3em] uppercase text-accent-orange mb-6"
      >
        {t.label}
      </span>

      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight mb-12"
      >
        {t.title}
        <br />
        <span class="text-accent-orange">{t.highlight}</span>
      </h2>

      <p
        class="text-lg md:text-xl text-copy/60 dark:text-dark-muted max-w-xl mx-auto leading-relaxed mb-10"
      >
        {t.description}
      </p>

    </div>

    <div
      class="flex flex-wrap justify-center gap-4 md:gap-8 pt-12 mb-5"
    >
      <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="social-link flex items-center gap-2 px-6 py-3 rounded-full border border-black/20 dark:border-dark-muted/30 text-copy/80 dark:text-dark-copy hover:text-accent-orange dark:hover:text-accent-orange hover:border-accent-orange/30 hover:bg-accent-orange/5 transition-all duration-300 text-sm font-medium"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
        {t.whatsapp}
      </a>
      <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="social-link flex items-center gap-2 px-6 py-3 rounded-full border border-black/20 dark:border-dark-muted/30 text-copy/80 dark:text-dark-copy hover:text-accent-orange dark:hover:text-accent-orange hover:border-accent-orange/30 hover:bg-accent-orange/5 transition-all duration-300 text-sm font-medium"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
        {t.instagram}
      </a>
      <a
        href="#"
        target="_blank"
        rel="noopener noreferrer"
        class="social-link flex items-center gap-2 px-6 py-3 rounded-full border border-black/20 dark:border-dark-muted/30 text-copy/80 dark:text-dark-copy hover:text-accent-orange dark:hover:text-accent-orange hover:border-accent-orange/30 hover:bg-accent-orange/5 transition-all duration-300 text-sm font-medium"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 6L12 13 2 6M4 4h16a2 2 0 012 2v12a2 2 0 01-2 2H4a2 2 0 01-2-2V6a2 2 0 012-2z"/></svg>
        {t.email}
      </a>
    </div>
  </div>
</section>

<style>
  .social-link svg {
    transition: stroke 0.3s ease, fill 0.3s ease;
  }
  .social-link:hover svg {
    stroke: #FF5C2B;
  }
  .social-link:hover svg circle[fill="currentColor"] {
    fill: #FF5C2B;
  }
</style>
