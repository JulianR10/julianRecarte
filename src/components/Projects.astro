---
import ProjectCard from "./ProjectCard.astro";
import SectionHeader from "./SectionHeader.astro";
import { projects } from "@data/projects";

interface ProjectItem {
  title: string;
  description: string;
}

interface Props {
  t: {
    label: string;
    title: string;
    highlight: string;
    viewProject: string;
    comingSoon: string;
    items: ProjectItem[];
  };
}

const { t } = Astro.props;
---

<section
  id="proyectos"
  class="relative md:z-[2] min-h-screen px-6 py-16 md:py-24"
>
  <div class="max-w-7xl mx-auto">
    <SectionHeader label={t.label} title={t.title} highlight={t.highlight} />

    <div
      data-reveal-stagger
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 md:gap-8"
    >
      {projects.map((project, i) => {
        const item = t.items[i];
        if (!item) return null;
        return (
          <ProjectCard
            title={item.title}
            description={item.description}
            tags={project.tags}
            href={project.href}
            image={project.image}
            style={project.style}
            viewProject={t.viewProject}
            comingSoon={project.href ? undefined : t.comingSoon}
          />
        );
      })}
    </div>
  </div>
</section>
