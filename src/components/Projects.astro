---
import ProjectCard from "./ProjectCard.astro";

const projects = [
  {
    title: "Nexus",
    description:
      "Plataforma interactiva con animaciones 3D y microinteracciones fluidas. Diseño editorial con tipografía protagonista.",
    tags: ["React", "Three.js", "GSAP", "Framer Motion"],
    style: "linear-gradient(135deg, rgba(255,92,43,0.4), rgba(255,92,43,0.15), rgba(91,31,255,0.3))",
  },
  {
    title: "Aether",
    description:
      "Experiencia cinematográfica de storytelling visual. Scroll narrativo con parallax y transiciones orgánicas.",
    tags: ["Next.js", "GSAP", "Lenis", "TailwindCSS"],
    style: "linear-gradient(135deg, rgba(91,31,255,0.4), rgba(91,31,255,0.15), rgba(255,92,43,0.3))",
  },
  {
    title: "Lumina",
    description:
      "E-commerce con enfoque en la experiencia de producto. Animaciones con intención y navegación fluida.",
    tags: ["Astro", "GSAP", "Shopify", "TypeScript"],
    style: "linear-gradient(135deg, rgba(255,92,43,0.3), rgba(242,236,228,0.5), rgba(91,31,255,0.4))",
  },
];
---

<section
  id="proyectos"
  class="min-h-screen px-6 py-32"
>
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 md:mb-20" data-reveal>
      <span
        class="inline-block text-xs font-medium tracking-[0.3em] uppercase text-accent-orange mb-6"
      >
        Proyectos
      </span>
      <h2
        class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight max-w-3xl"
      >
        Trabajos <span class="text-accent-orange">destacados</span>
      </h2>
    </div>

    <div
      data-reveal-stagger
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8"
    >
      {projects.map((project) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </div>
</section>
