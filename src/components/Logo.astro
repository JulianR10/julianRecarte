---
interface Props {
  dataNavLogo?: boolean;
  dataFooterLogo?: boolean;
  className?: string;
}

const { dataNavLogo, dataFooterLogo, className = "" } = Astro.props;
const attrs: Record<string, string | boolean> = {};
if (dataNavLogo) attrs["data-nav-logo"] = true;
if (dataFooterLogo) attrs["data-footer-logo"] = true;
---

<a
  href={import.meta.env.BASE_URL || "/"}
  {...attrs}
  class={"inline-block text-[2rem] font-bold font-clash leading-none tracking-[-4px] no-underline transition-transform duration-300 hover:scale-110 hover:rotate-[25deg]" + (className ? " " + className : "")}
>
  <span class="text-copy dark:text-dark-copy">J</span><span class="text-accent-orange">R</span>
</a>
