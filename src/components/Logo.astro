---
interface Props {
  dataNavLogo?: boolean;
  dataFooterLogo?: boolean;
  className?: string;
  lang?: string;
}

const logoLabels: Record<string, string> = {
  es: "Julián Recarte - Inicio",
  en: "Julián Recarte - Home",
  it: "Julián Recarte - Home",
};

const { dataNavLogo, dataFooterLogo, className = "", lang = "es" } = Astro.props;
const logoLabel = logoLabels[lang] || logoLabels.es;
const attrs: Record<string, string | boolean> = {};
if (dataNavLogo) attrs["data-nav-logo"] = true;
if (dataFooterLogo) attrs["data-footer-logo"] = true;
---

<a
  href={import.meta.env.BASE_URL || "/"}
  {...attrs}
  class={"inline-block text-[2rem] font-bold leading-none tracking-[-4px] no-underline transition-transform duration-300 hover:scale-110 hover:rotate-[25deg]" + (className ? " " + className : "")}
  aria-label={logoLabel}
>
  <span class="text-copy dark:text-dark-copy">J</span><span class="text-accent-orange">R</span>
</a>
