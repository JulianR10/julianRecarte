---

---

<div
  id="waves"
  class="fixed inset-0 pointer-events-none z-0 overflow-hidden"
  aria-hidden="true"
>
  <svg
    class="w-full h-full"
    viewBox="0 0 1440 900"
    preserveAspectRatio="xMidYMid slice"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      <filter id="wave-blur">
        <feGaussianBlur stdDeviation="2.52" />
      </filter>
    </defs>
    <path
      class="wave wave-1"
      d="M-200,300 C50,100 300,500 550,300 C800,100 1050,500 1300,300 C1550,100 1800,500 2000,300"
      fill="none"
      stroke-width="1.5"
      stroke-linecap="round"
      opacity="0.12"
      filter="url(#wave-blur)"
    />
    <path
      class="wave wave-2"
      d="M-200,500 C50,700 300,300 550,500 C800,700 1050,300 1300,500 C1550,700 1800,300 2000,500"
      fill="none"
      stroke-width="1.5"
      stroke-linecap="round"
      opacity="0.1"
      filter="url(#wave-blur)"
    />
    <path
      class="wave wave-3"
      d="M-200,700 C50,500 300,900 550,700 C800,500 1050,900 1300,700 C1550,500 1800,900 2000,700"
      fill="none"
      stroke-width="1"
      stroke-linecap="round"
      opacity="0.07"
      filter="url(#wave-blur)"
    />
  </svg>
</div>

<style>
  .wave-1,
  .wave-3 {
    stroke: var(--clr-accent-orange);
  }

  .wave-2 {
    stroke: var(--clr-accent-purple);
  }

  @media (max-width: 767px) {
    .wave-1,
    .wave-2,
    .wave-3 {
      filter: none;
    }
  }
</style>

<script>
  (async function () {
    const isMobile = window.innerWidth < 768;
    if (isMobile) return;

    const gsap = (await import("gsap")).default;

    const waves = [
      {
        el: document.querySelector(".wave-1"),
        morphs: [
          "M-200,300 C50,100 300,500 550,300 C800,100 1050,500 1300,300 C1550,100 1800,500 2000,300",
          "M-200,300 C50,500 300,100 550,300 C800,500 1050,100 1300,300 C1550,500 1800,100 2000,300",
        ],
        dur: 10,
      },
      {
        el: document.querySelector(".wave-2"),
        morphs: [
          "M-200,500 C50,700 300,300 550,500 C800,700 1050,300 1300,500 C1550,700 1800,300 2000,500",
          "M-200,500 C50,300 300,700 550,500 C800,300 1050,700 1300,500 C1550,300 1800,700 2000,500",
        ],
        dur: 13,
      },
      {
        el: document.querySelector(".wave-3"),
        morphs: [
          "M-200,700 C50,500 300,900 550,700 C800,500 1050,900 1300,700 C1550,500 1800,900 2000,700",
          "M-200,700 C50,900 300,500 550,700 C800,900 1050,500 1300,700 C1550,900 1800,500 2000,700",
        ],
        dur: 16,
      },
    ];

    waves.forEach(({ el, morphs, dur }) => {
      if (!el) return;
      gsap.to(el, {
        attr: { d: morphs[1] },
        duration: dur,
        repeat: -1,
        yoyo: true,
        ease: "sine.inOut",
      });
    });
  })();
</script>
