---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description: string;
  tags: string[];
  style: string;
  viewProject: string;
  href?: string;
  image?: ImageMetadata;
  comingSoon?: string;
}

const { title, description, tags, style, viewProject, href, image, comingSoon } = Astro.props;
---

<article
  data-project-card
  class="group relative rounded-2xl bg-white/50 dark:bg-dark-card/50 border border-black/5 dark:border-dark-muted/20 md:hover:border-black/10 md:dark:hover:border-dark-muted/30 transition-shadow duration-500 md:transition-[box-shadow,border-color] duration-500 shadow-[0_4px_20px_rgba(0,0,0,0.04)] md:hover:shadow-xl md:hover:shadow-black/5"
>
  <div data-card-shine class="pointer-events-none absolute inset-0 rounded-2xl opacity-0 z-[1]"></div>
  <div
    class="aspect-[4/3] relative overflow-hidden rounded-2xl"
    style={image ? undefined : "background: " + style}
  >
    {image ? (
      <Image src={image} alt={title} width={400} height={300} loading="lazy" class="w-full h-full object-contain p-8" style={`background: ${style}; filter: drop-shadow(0 6px 20px rgba(0,0,0,0.25))`} />
    ) : (
      <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iNDAiIGhlaWdodD0iNDAiIHZpZXdCb3g9IjAgMCA0MCA0MCIgeG1sbnM9Imh0dHA6Ly93d3cudzMub3JnLzIwMDAvc3ZnIj48cGF0aCBkPSJNMCAwaDQwdjQwSDB6IiBmaWxsPSJub25lIi8+PHBhdGggZD0iTTAgMjBoNDBNMjAgMHY0MCIgc3Ryb2tlPSIjZmZmIiBzdHJva2Utd2lkdGg9IjAuNSIgc3Ryb2tlLW9wYWNpdHk9IjAuMDYiLz48L3N2Zz4=')] opacity-50">
      </div>
    )}
    <div
      class="absolute top-4 left-4 flex gap-1.5"
    >
      <span class="w-2.5 h-2.5 rounded-full bg-white/20 dark:bg-dark-muted/30"></span>
      <span class="w-2.5 h-2.5 rounded-full bg-white/20 dark:bg-dark-muted/30"></span>
      <span class="w-2.5 h-2.5 rounded-full bg-white/20 dark:bg-dark-muted/30"></span>
    </div>
    {comingSoon && !href ? (
      <div class="absolute top-4 right-4">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-medium tracking-wider uppercase bg-accent-orange/90 text-white backdrop-blur-sm shadow-sm">
          {comingSoon}
        </span>
      </div>
    ) : null}
    <div
      class="absolute inset-0 bg-black/0 md:group-hover:bg-black/10 dark:bg-white/0 md:dark:group-hover:bg-white/10 transition-colors duration-500"
    >
    </div>
    <div
      class="absolute inset-0 hidden md:flex items-center justify-center opacity-0 group-hover:opacity-100 transition-all duration-500"
    >
      {href ? (
        <a
          href={href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-white text-sm font-medium tracking-wider uppercase bg-white/10 dark:bg-dark-card backdrop-blur-md px-6 py-3 rounded-full border border-white/20 hover:bg-white/20 transition-colors duration-300"
        >
          {viewProject}
        </a>
      ) : (
        <span
          class="text-white text-sm font-medium tracking-wider uppercase bg-white/10 dark:bg-dark-card backdrop-blur-md px-6 py-3 rounded-full border border-white/20"
        >
          {viewProject}
        </span>
      )}
    </div>
  </div>

  <div class="p-6 md:p-8">
    <h3
      class="text-2xl font-medium mb-3 text-accent-purple transition-colors duration-300 md:group-hover:text-accent-orange"
    >
      {title}
    </h3>
    <p class="text-copy/60 dark:text-dark-muted text-sm leading-relaxed mb-6">
      {description}
    </p>
    {href ? (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class="md:hidden inline-flex items-center justify-center text-sm font-medium tracking-wider uppercase text-accent-orange hover:text-accent-orange/80 transition-colors duration-300"
      >
        {viewProject}
      </a>
    ) : (
      <span
        class="md:hidden inline-flex items-center justify-center text-sm font-medium tracking-wider uppercase text-accent-orange"
      >
        {viewProject}
      </span>
    )}
  </div>
</article>
