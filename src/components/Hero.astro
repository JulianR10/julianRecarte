---
import { Image } from "astro:assets";
import heroImg from "@assets/images/yo.webp";

interface Props {
  t: {
    label: string;
    greetingPrefix: string;
    greetingName: string;
    subtitle: string;
    description: string;
    highlightWord?: string;
    cta: string;
    viewProjects: string;
    contact: string;
  };
}

const { t } = Astro.props;

function highlightParts(line: string, word?: string): Array<{ text: string; highlighted: boolean }> {
  if (!word) return [{ text: line, highlighted: false }];
  const regex = new RegExp(`(${word})`, "gi");
  const parts = line.split(regex);
  return parts.map((part) => ({
    text: part,
    highlighted: part.toLowerCase() === word.toLowerCase(),
  }));
}
---

<section
  id="hero"
  class="relative min-h-screen md:h-screen md:sticky md:top-0 md:z-[1] flex items-center px-6 py-16 md:py-24 overflow-hidden"
>
  <div class="max-w-7xl mx-auto w-full flex items-center justify-center md:justify-between gap-12">
    <div data-hero-text class="max-w-3xl text-center md:text-left">
      <span
        data-reveal
        class="relative inline-block text-sm font-medium tracking-[0.3em] uppercase text-accent-orange mb-6 md:mb-8"
      >
        <span class="zap-text">{t.label}</span>
        <span data-zap-clone class="absolute inset-0 pointer-events-none zap-glow-brand" aria-hidden="true">{t.label}</span>
        <span data-zap-clone class="absolute inset-0 pointer-events-none zap-glow-orange" aria-hidden="true">{t.label}</span>
      </span>

      <h1
        data-reveal-heading
        class="text-[2.5rem] sm:text-4xl md:text-5xl lg:text-6xl font-medium tracking-tight mb-4 leading-tight text-copy dark:text-dark-copy text-balance"
      >
        {t.greetingPrefix}<span class="text-accent-orange whitespace-nowrap">{t.greetingName}</span>
      </h1>

      <div class="flex md:hidden justify-center my-8">
        <div class="w-52 h-52 sm:w-60 sm:h-60 rounded-[2rem] p-[2px] bg-gradient-to-br from-accent-warm to-accent-warm/5 dark:bg-gradient-to-tl dark:from-accent-warm dark:to-accent-warm/5 shadow-xl">
          <div class="w-full h-full rounded-[2rem] overflow-hidden">
            <Image
              src={heroImg}
              alt="Julián Recarte"
              width={1024}
              height={1536}
              class="w-full h-full object-cover scale-[1.2] translate-y-[4%]"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>

      <p
        data-reveal
        class="text-base sm:text-lg md:text-xl tracking-tight mb-6 text-copy/60 dark:text-dark-copy/60 text-balance"
      >
        {t.subtitle}
      </p>

      {
        t.description.split('\n').map((line) => (
          <p data-reveal class="text-copy/50 dark:text-dark-muted leading-relaxed text-sm sm:text-base md:text-lg mb-0 max-w-2xl text-balance">
            {highlightParts(line.trim(), t.highlightWord).map((part) =>
              part.highlighted ? <span class="highlight-word">{part.text}</span> : part.text
            )}
          </p>
        ))
      }

      <p data-reveal class="font-satoshi text-base sm:text-lg md:text-xl italic text-accent-orange/80 mt-6 mb-8 text-balance">
        {t.cta}
      </p>

      <div data-reveal class="flex flex-col sm:flex-row gap-3 justify-center md:justify-start items-center">
      <a
        href="#proyectos"
        class="inline-flex items-center justify-center gap-2 w-auto px-6 py-3 md:px-8 md:py-4 bg-gradient-to-r from-accent-orange to-accent-pastel backdrop-blur-lg text-white rounded-full font-medium text-sm md:text-base tracking-wider uppercase shadow-lg"
      >
        {t.viewProjects}
      </a>
        <a
          href="#contacto"
          class="group relative inline-flex items-center justify-center gap-2 w-auto px-6 py-3 md:px-8 md:py-4 rounded-full font-medium text-sm md:text-base tracking-wider uppercase overflow-hidden text-accent-orange hover:text-white transition-colors duration-300"
          style="border: 2px solid transparent; background-image: linear-gradient(var(--bg-hex), var(--bg-hex)), linear-gradient(to right, var(--clr-accent-orange), var(--clr-accent-pastel)); background-origin: border-box; background-clip: padding-box, border-box;"
        >
          <span class="absolute inset-0 rounded-full bg-gradient-to-r from-accent-orange to-accent-pastel opacity-0 group-hover:opacity-100 transition-opacity duration-300"></span>
          <span class="relative z-10">{t.contact}</span>
        </a>
      </div>

    </div>

    <div data-hero-image class="hidden md:flex items-center justify-center w-full max-w-lg shrink-0">
      <div class="w-80 h-80 lg:w-[28rem] lg:h-[28rem] rounded-[2rem] p-[2px] bg-gradient-to-br from-accent-warm to-accent-warm/5 dark:bg-gradient-to-tl dark:from-accent-warm dark:to-accent-warm/5 shadow-xl">
        <div class="w-full h-full rounded-[2rem] overflow-hidden">
          <Image
            src={heroImg}
            alt="Julián Recarte"
            class="w-full h-full object-cover scale-[1.2] translate-y-[4%]"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>

  </div>

</section>

<style>
  .highlight-word {
    background-color: rgba(var(--rgb-accent-orange), 0.13);
    border-radius: 3px;
    padding: 0 4px;
    font-style: italic;
    font-weight: 500;
  }
</style>


