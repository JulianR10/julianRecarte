<div id="cursor" class="hidden md:block"></div>

<style>
  #cursor {
    position: fixed;
    width: 16px;
    height: 16px;
    border: 1.5px solid #ff5c2b;
    border-radius: 50%;
    pointer-events: none;
    z-index: 9999;
    transition: width 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      height 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      background-color 0.35s ease,
      border-color 0.35s ease;
    will-change: transform;
    top: 0;
    left: 0;
  }

  #cursor.is-hover {
    width: 48px;
    height: 48px;
    background-color: rgba(255, 92, 43, 0.08);
    border-color: rgba(255, 92, 43, 0.4);
  }
</style>

<script>
  import gsap from "gsap";

  (function () {
    const cursor = document.getElementById("cursor");
    if (!cursor || "ontouchstart" in window) return;

    let mx = 0,
      my = 0;

    document.addEventListener("mousemove", (e) => {
      mx = e.clientX;
      my = e.clientY;
    });

    gsap.ticker.add(() => {
      gsap.to(cursor, {
        x: mx - 8,
        y: my - 8,
        duration: 0.25,
        ease: "power2.out",
        overwrite: "auto",
      });
    });

    document
      .querySelectorAll(
        "a, button, [data-hoverable], [data-magnetic], .project-card"
      )
      .forEach((el) => {
        el.addEventListener("mouseenter", () =>
          cursor.classList.add("is-hover")
        );
        el.addEventListener("mouseleave", () =>
          cursor.classList.remove("is-hover")
        );
      });
  })();
</script>
