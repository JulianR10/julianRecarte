---
interface TestimonialItem {
  quote: string;
  initials: string;
  name: string;
  role: string;
  company: string;
}

interface Props {
  t: {
    label: string;
    title: string;
    highlight: string;
    items: TestimonialItem[];
  };
}

const { t } = Astro.props;
---

<section
  id="testimonios"
  class="px-6 py-16 md:py-32 overflow-hidden"
>
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 md:mb-20 text-center" data-reveal>
      <span
        class="inline-block text-xs font-medium tracking-[0.3em] uppercase text-accent-orange mb-6"
      >
        {t.label}
      </span>
      <h2
        data-reveal-heading
        class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight"
      >
        {t.title} <span class="text-accent-orange">{t.highlight}</span>
      </h2>
    </div>

    <div
      data-reveal-stagger
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 md:gap-8"
    >
      {t.items.map((item: TestimonialItem) => (
        <div class="relative p-8 rounded-2xl bg-white/50 dark:bg-dark-card/50 border border-black/5 dark:border-dark-muted/20 shadow-[0_4px_20px_rgba(0,0,0,0.04)] md:hover:shadow-xl md:hover:shadow-black/5 md:dark:hover:shadow-black/20 transition-shadow duration-500 md:transition-all duration-500">
          <div class="flex items-center gap-1 mb-4">
            {Array.from({ length: 5 }).map((_, i) => (
              <svg key={i} class="w-4 h-4 text-accent-orange" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          <p class="text-copy/70 dark:text-dark-muted text-sm leading-relaxed mb-6">
            "{item.quote}"
          </p>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-accent-orange/30 to-accent-purple/30 flex items-center justify-center text-xs font-bold text-accent-orange">
              {item.initials}
            </div>
            <div>
              <p class="text-sm font-bold text-copy dark:text-dark-copy">{item.name}</p>
              <p class="text-xs text-copy/50 dark:text-dark-muted/60">{item.role} — {item.company}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
