---
import SectionHeader from "./SectionHeader.astro";

interface TestimonialItem {
  quote: string;
  initials: string;
  name: string;
  role: string;
  company: string;
}

interface Props {
  t: {
    label: string;
    title: string;
    highlight: string;
    starRating: string;
    prev: string;
    next: string;
    carouselLabel: string;
    items: TestimonialItem[];
  };
}

const { t } = Astro.props;
---

<section id="testimonios" class="relative z-[1] px-6 py-16 md:py-24 overflow-visible">
  <div class="max-w-7xl mx-auto">
    <SectionHeader label={t.label} title={t.title} highlight={t.highlight} id="test-title" />

    <div id="testimonios-carousel" class="flex items-center max-w-3xl mx-auto" role="region" aria-roledescription="carousel" aria-label={t.carouselLabel}>
      <button id="test-prev" type="button"
        class="shrink-0 w-10 h-10 md:w-12 md:h-12 rounded-full bg-white dark:bg-dark-card border border-black/5 dark:border-dark-muted/20 shadow-md flex items-center justify-center text-copy dark:text-dark-copy hover:bg-accent-orange hover:text-white hover:border-accent-orange transition-all duration-300"
        aria-label={t.prev}>
        <svg class="w-4 h-4 md:w-5 md:h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <div id="testimonios-track" class="relative flex-1 mx-3 md:mx-9" style="min-height: 380px;" aria-live="polite">
        {t.items.map((item, i) => (
          <article
            class="testimonio-card absolute inset-x-0 top-0 p-6 md:p-10 lg:p-12 rounded-[1.75rem] bg-white dark:bg-dark-card border border-black/5 dark:border-dark-muted/20 shadow-xl transition-[transform,opacity] duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
          >
            <div class="flex items-center gap-1 mb-6 md:mb-8" role="img" aria-label={t.starRating}>
              {Array.from({ length: 5 }).map((_, j) => (
                <svg key={j} class="w-5 h-5 text-accent-orange" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-copy/70 dark:text-dark-muted text-base md:text-lg leading-relaxed mb-8 md:mb-10">
              &ldquo;{item.quote}&rdquo;
            </p>
            <div class="flex items-center gap-3">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br from-accent-orange/30 to-accent-purple/30 flex items-center justify-center text-xs font-bold text-accent-orange flex-shrink-0">
                {item.initials}
              </div>
              <div class="min-w-0">
                <h3 class="text-base font-bold text-copy dark:text-dark-copy truncate">{item.name}</h3>
                <p class="text-sm text-copy/50 dark:text-dark-muted/60 truncate">{item.role} &mdash; {item.company}</p>
              </div>
            </div>
          </article>
        ))}
      </div>

      <button id="test-next" type="button"
        class="shrink-0 w-10 h-10 md:w-12 md:h-12 rounded-full bg-white dark:bg-dark-card border border-black/5 dark:border-dark-muted/20 shadow-md flex items-center justify-center text-copy dark:text-dark-copy hover:bg-accent-orange hover:text-white hover:border-accent-orange transition-all duration-300"
        aria-label={t.next}>
        <svg class="w-4 h-4 md:w-5 md:h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .testimonio-card {
    min-height: 300px;
    opacity: 0;
    transform: translateX(60px) scale(0.94);
  }
  .card-active {
    opacity: 1;
    transform: translateX(0) scale(1);
    z-index: 3;
    pointer-events: auto;
    transition: transform var(--dur-slow) ease;
  }
  .card-peek-right {
    opacity: 0.45;
    transform: translateX(28px) scale(0.96);
    z-index: 2;
    pointer-events: none;
  }
  .card-peek-left {
    opacity: 0.45;
    transform: translateX(-28px) scale(0.96);
    z-index: 2;
    pointer-events: none;
  }
  .card-hidden {
    opacity: 0;
    transform: translateX(60px) scale(0.94);
    z-index: 1;
    pointer-events: none;
  }
  @media (min-width: 768px) {
    #testimonios-track { min-height: 460px; }
  }
  @media (min-width: 1024px) {
    #testimonios-track { min-height: 500px; }
  }
</style>

