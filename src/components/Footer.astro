---
interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-black/5 dark:border-dark-muted/20 py-5">
  <div
    class="max-w-[87%] mx-auto flex flex-col md:flex-row items-center justify-between gap-6 px-6"
  >
    <a
      href={import.meta.env.BASE_URL || "/"}
      class="inline-block text-[2rem] font-bold font-clash leading-none tracking-[-4px] no-underline transition-transform duration-300 hover:scale-110 hover:rotate-[25deg]"
    >
      <span class="text-copy dark:text-dark-copy">J</span><span class="text-accent-orange">R</span>
    </a>
    <p class="text-sm text-copy/30 dark:text-dark-muted/50 order-3 md:order-2">
      {(t.copyright || "© {year} Julián Recarte").replace("{year}", String(year))}
    </p>
  </div>
</footer>
