---
import Logo from "./Logo.astro";
import firma from "@assets/images/firma.png";

interface Props {
  t: {
    copyright: string;
  };
  lang?: string;
}

const { t, lang = "es" } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-black/5 dark:border-dark-muted/20 py-5">
  <div
    class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 px-6"
  >
    <Logo lang={lang} />
    <p class="text-sm text-copy/50 dark:text-dark-muted/70 flex items-center gap-3 order-3 md:order-2">
      {(t.copyright || "© {year}").replace("{year}", String(year))}
      <img
        src={firma.src}
        alt=""
        width={100}
        height={24}
        class="signature h-6 w-auto"
        aria-hidden="true"
        loading="lazy"
        decoding="async"
      />
    </p>
  </div>
</footer>

<style>
  .signature {
    filter: brightness(0);
    opacity: 0.5;
  }

  :global(.dark) .signature {
    filter: brightness(0) invert(1);
    opacity: 0.7;
  }
</style>
