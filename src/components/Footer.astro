---
import Logo from "./Logo.astro";

interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="border-t border-black/5 dark:border-dark-muted/20 py-5">
  <div
    class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6 px-6"
  >
    <Logo dataFooterLogo />
    <p class="text-sm text-copy/50 dark:text-dark-muted/70 order-3 md:order-2">
      {(t.copyright || "© {year} Julián Recarte").replace("{year}", String(year))}
    </p>
  </div>
</footer>
