---
import { Image } from "astro:assets";
import SectionHeader from "./SectionHeader.astro";
import { steps } from "@data/process";

interface ProcessStep {
  title: string;
  description: string;
}

interface Props {
  t: {
    label: string;
    title: string;
    highlight: string;
    stepLabel: string;
    steps: ProcessStep[];
  };
}

const { t } = Astro.props;
---

<section
  id="proceso"
  class="relative z-[1] min-h-screen px-6 py-16 md:py-24 overflow-hidden"
>
  <div class="max-w-7xl mx-auto">
    <SectionHeader label={t.label} title={t.title} highlight={t.highlight} id="proc-title" />

    <div id="process-wrap" class="relative">
      <div
        class="hidden md:block absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-px"
        style="background: linear-gradient(to bottom, transparent 0%, rgba(91,31,255,0.2) 15%, rgba(255,92,43,0.2) 50%, rgba(91,31,255,0.2) 85%, transparent 100%);"
      >
      </div>
      <div id="process-line-wrap" class="hidden md:block absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-[2px] overflow-hidden">
        <div id="process-line" class="absolute top-0 left-0 w-full h-full origin-top" style="transform: scaleY(0); background: linear-gradient(to bottom, transparent 0%, rgb(255,92,43) 10%, rgb(91,31,255) 50%, rgb(255,92,43) 90%, transparent 100%);"></div>
      </div>

      {steps.map((step, i) => (
        <div
          class="relative grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-16 lg:gap-24 py-6 md:py-8"
          data-reveal
          data-process-step={i}
        >
          <div
            class={`${i % 2 === 1 ? "md:order-2" : ""}`}
          >
            <div
              class="relative aspect-[4/3] rounded-2xl overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.04)] dark:bg-dark-card md:hover:shadow-xl md:hover:shadow-black/5 md:dark:hover:shadow-black/20 transition-shadow duration-500 md:transition-all duration-500"
              style={`background: ${step.gradient}`}
            >
              <Image
                src={step.image}
                alt={t.steps[i].title}
                width={800}
                height={600}
                loading="lazy"
                decoding="async"
                class="absolute inset-0 w-full h-full object-cover"
              />
              <div
                class="absolute top-4 left-4 flex gap-1.5"
              >
                <span
                  class="w-2 h-2 rounded-full bg-white/20 dark:bg-dark-muted/30"
                ></span>
                <span
                  class="w-2 h-2 rounded-full bg-white/20 dark:bg-dark-muted/30"
                ></span>
                <span
                  class="w-2 h-2 rounded-full bg-white/20 dark:bg-dark-muted/30"
                ></span>
              </div>
            </div>
          </div>

          <div
            class={`flex flex-col justify-center ${i % 2 === 1 ? "md:order-1" : ""}`}
          >
            <span
              class="inline-block text-xs font-medium tracking-[0.3em] uppercase text-accent-orange/60 mb-4"
            >
              {t.stepLabel} {step.num}
            </span>
            <h3
              class="text-3xl md:text-4xl lg:text-5xl font-medium mb-6 leading-tight"
            >
              {t.steps[i].title}
            </h3>
            <p class="text-copy/60 dark:text-dark-muted leading-relaxed text-base md:text-lg" style="text-wrap: balance;">
              {t.steps[i].description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
