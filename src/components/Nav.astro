---
import Logo from "./Logo.astro";
import LangSelector from "./LangSelector.astro";

interface Props {
  lang: string;
  t: {
    projects: string;
    process: string;
    contact: string;
    lightMode: string;
    darkMode: string;
    closeMenu: string;
    openMenu: string;
  };
}

const { lang, t } = Astro.props;

const navItems = [
  { id: "proyectos", label: t.projects },
  { id: "proceso", label: t.process },
  { id: "contacto", label: t.contact },
];
---

<nav id="main-nav" aria-label="Main navigation" class="fixed top-0 left-0 right-0 z-50 py-4 md:py-5" style="view-transition-name: nav" data-lenis-prevent>
  <div id="progress-bar" aria-hidden="true" class="absolute bottom-0 left-0 h-[2px] bg-gradient-to-r from-accent-orange to-accent-purple origin-left" style="transform: scaleX(0);"></div>
  <div class="max-w-7xl mx-auto flex items-center px-6">
    <div class="flex-1 md:flex-none text-left">
      <Logo dataNavLogo lang={lang} />
    </div>

    <div class="hidden md:flex flex-1 justify-center items-center gap-8">
      {navItems.map((item) => (
        <a href={`#${item.id}`} class="desktop-link text-sm font-semibold tracking-widest uppercase text-copy/80 dark:text-dark-copy hover:text-accent-orange hover:tracking-[0.15em] transition-all duration-300">
          {item.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2 md:gap-3">
      <LangSelector lang={lang} mode="desktop" />

      <div id="theme-toggle" class="hidden md:relative md:flex items-center">
        <div id="theme-indicator" class="absolute w-8 h-8 rounded-full bg-accent-orange shadow-sm shadow-accent-orange/40 transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)]"></div>
        <button id="light-toggle" class="theme-btn relative z-10 w-8 h-8 rounded-full flex items-center justify-center" aria-label={t.lightMode}>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5" />
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
          </svg>
        </button>
        <button id="dark-toggle" class="theme-btn relative z-10 w-8 h-8 rounded-full flex items-center justify-center" aria-label={t.darkMode}>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
      </div>

      <button id="menu-btn" aria-expanded="false" aria-controls="nav-overlay"
        class="md:hidden w-11 h-11 md:w-12 md:h-12 rounded-full bg-gradient-to-br from-accent-orange via-accent-warm to-accent-pastel text-white shadow-lg shadow-accent-orange/30 cursor-pointer border-none outline-none flex items-center justify-center hover:scale-105 active:scale-95 transition-transform duration-300"
        data-close-label={t.closeMenu} data-open-label={t.openMenu} aria-label={t.openMenu}
      >
        <svg class="w-5 h-5 md:w-5 md:h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </div>
</nav>

<div
  id="nav-overlay"
  class="nav-overlay-hidden fixed inset-0 z-40 md:hidden bg-black/80 backdrop-blur-sm transition-opacity duration-300"
  role="dialog"
  aria-modal="true"
  aria-hidden="true"
  inert
>
  <div class="absolute right-5 md:right-8 top-28 md:top-32 flex flex-col items-end gap-4 md:gap-5">
    {navItems.map((item, i) => (
      <a
        id={`nl-${i + 1}`}
        href={`#${item.id}`}
        class="nav-link relative px-6 py-3 md:px-6 md:py-3 rounded-full text-sm md:text-sm font-medium tracking-widest uppercase text-white bg-accent-orange shadow-lg hover:bg-accent-orange/80 transition-colors duration-300"
      >
        {item.label}
      </a>
    ))}

    <div class="w-full h-px bg-white/20 my-3"></div>

    <div class="flex items-center gap-4">
      <LangSelector lang={lang} mode="overlay" />

      <div class="w-px h-6 bg-white/25"></div>

      <div class="flex items-center gap-2">
        <button id="overlay-light-toggle" class="w-10 h-10 rounded-full flex items-center justify-center bg-white/10 border border-white/20 text-white/80 hover:text-white hover:bg-white/20 transition-colors duration-300" aria-label={t.lightMode}>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5" />
            <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
          </svg>
        </button>
        <button id="overlay-dark-toggle" class="w-10 h-10 rounded-full flex items-center justify-center bg-white/10 border border-white/20 text-white/80 hover:text-white hover:bg-white/20 transition-colors duration-300" aria-label={t.darkMode}>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .nav-overlay-hidden {
    opacity: 0;
    pointer-events: none;
  }
  .nav-overlay-visible {
    opacity: 1;
    pointer-events: auto;
  }
  #nav-overlay > div {
    transition: transform var(--dur-slow) cubic-bezier(0.16, 1, 0.3, 1), opacity var(--dur-slow) ease;
  }
  .nav-overlay-hidden > div {
    transform: translateX(60px);
    opacity: 0;
  }
  .nav-overlay-visible > div {
    transform: translateX(0);
    opacity: 1;
  }
  #nav-overlay .nav-link,
  #nav-overlay :global(#overlay-lang-btn),
  #nav-overlay #overlay-light-toggle,
  #nav-overlay #overlay-dark-toggle {
    opacity: 0;
    transform: translateX(40px);
    transition: transform var(--dur-slow) cubic-bezier(0.16, 1, 0.3, 1), opacity var(--dur-slow) ease;
    transition-delay: 0.05s;
  }
  #nav-overlay.nav-overlay-visible .nav-link:nth-child(1) { transition-delay: 0.05s; }
  #nav-overlay.nav-overlay-visible .nav-link:nth-child(2) { transition-delay: 0.10s; }
  #nav-overlay.nav-overlay-visible .nav-link:nth-child(3) { transition-delay: 0.15s; }
  #nav-overlay.nav-overlay-visible :global(#overlay-lang-btn) { transition-delay: 0.20s; }
  #nav-overlay.nav-overlay-visible #overlay-light-toggle { transition-delay: 0.25s; }
  #nav-overlay.nav-overlay-visible #overlay-dark-toggle { transition-delay: 0.30s; }
  #nav-overlay.nav-overlay-visible .nav-link,
  #nav-overlay.nav-overlay-visible :global(#overlay-lang-btn),
  #nav-overlay.nav-overlay-visible #overlay-light-toggle,
  #nav-overlay.nav-overlay-visible #overlay-dark-toggle {
    opacity: 1;
    transform: translateX(0);
  }
  .desktop-link.active {
    color: var(--clr-accent-orange);
  }

  #main-nav {
    background-color: color-mix(in srgb, var(--bg-hex) 95%, transparent);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  :global(.dark) #main-nav {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
  }
</style>

<script>
  import { initNav, destroyNav } from "@scripts/nav";
  import { createLifecycle } from "@scripts/lifecycle";
  createLifecycle(initNav, destroyNav);
</script>