---
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  jobTitle?: string;
  lang?: string;
  t?: Record<string, string>;
}

const {
  title = "Julián Recarte | Creative Frontend Developer",
  description = "Convierto marcas en experiencias web interactivas.",
  jobTitle = "Creative Frontend Developer",
  lang = "es",
  t = { skipLink: "Ir al contenido principal", backToTop: "Volver arriba" },
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://julianrecarte.github.io/julianRecarte/${lang}/`} />
    <meta property="og:image" content="https://julianrecarte.github.io/julianRecarte/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : lang === "en" ? "en_US" : "it_IT"} />
    <meta property="og:site_name" content="Julián Recarte" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://julianrecarte.github.io/julianRecarte/og-image.png" />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="es" href="https://julianrecarte.github.io/julianRecarte/es/" />
    <link rel="alternate" hreflang="en" href="https://julianrecarte.github.io/julianRecarte/en/" />
    <link rel="alternate" hreflang="it" href="https://julianrecarte.github.io/julianRecarte/it/" />
    <link rel="alternate" hreflang="x-default" href="https://julianrecarte.github.io/julianRecarte/" />
    <link rel="canonical" href={`https://julianrecarte.github.io/julianRecarte/${lang}/`} />

    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Julián Recarte",
      "jobTitle": jobTitle,
      description,
      "url": `https://julianrecarte.github.io/julianRecarte/${lang}/`,
      "knowsAbout": [
        "Frontend Development",
        "React",
        "Astro",
        "GSAP",
        "TailwindCSS",
        "Three.js",
        "TypeScript",
        "Framer Motion"
      ],
      "knowsLanguage": ["Spanish", "English", "Italian"]
    })}></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Clash+Display:wght@400;500;600;700&family=Satoshi:wght@400;500;700&family=DM+Serif+Display:ital@0;1&display=swap"
      rel="stylesheet"
    />

    <script>
      (function () {
        const stored = localStorage.getItem("dark-mode");
        const prefers = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "true" || (stored === null && prefers)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body>
    <div id="preloader" aria-hidden="true">
      <span class="text-[3rem] md:text-[4rem] font-bold font-clash leading-none tracking-[-6px]">
        <span id="pl-j" class="text-copy dark:text-dark-copy">J</span><span id="pl-r" class="text-accent-orange">R</span>
      </span>
    </div>
    <script>
      import gsap from "gsap";

      window.addEventListener("load", () => {
        const preloader = document.getElementById("preloader");
        if (!preloader) return;

        const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
        if (reducedMotion) {
          preloader.style.display = "none";
          return;
        }

        const safety = setTimeout(() => {
          preloader.style.display = "none";
        }, 3000);

        setTimeout(() => {
          try {
            const plJ = document.getElementById("pl-j");
            const plR = document.getElementById("pl-r");
            const navLogo = document.querySelector("#main-nav > div > div:first-child a:first-child");
            if (!navLogo) throw new Error("navLogo not found");
            const navJ = navLogo.querySelector("span:first-child");
            const navR = navLogo.querySelector("span:last-child");
            if (!plJ || !plR || !navJ || !navR) throw new Error("spans not found");

            gsap.set([plJ, plR], { display: "inline-block" });

            const plJRect = plJ.getBoundingClientRect();
            const plRRect = plR.getBoundingClientRect();
            const navJRect = navJ.getBoundingClientRect();
            const navRRect = navR.getBoundingClientRect();

            const scaleJ = navJRect.width / plJRect.width;
            const scaleR = navRRect.width / plRRect.width;

            const dJ = {
              x: navJRect.left + navJRect.width / 2 - (plJRect.left + plJRect.width / 2),
              y: navJRect.top + navJRect.height / 2 - (plJRect.top + plJRect.height / 2),
            };
            const dR = {
              x: navRRect.left + navRRect.width / 2 - (plRRect.left + plRRect.width / 2),
              y: navRRect.top + navRRect.height / 2 - (plRRect.top + plRRect.height / 2),
            };

            const tl = gsap.timeline({
              defaults: { ease: "power4.inOut", duration: 1.2 },
              onComplete: () => {
                clearTimeout(safety);
                preloader.style.display = "none";
              },
            });

            tl.set(plJ, { rotation: -6 });
            tl.set(plR, { rotation: 6 });

            tl.to(plJ, {
              x: dJ.x, y: dJ.y,
              rotation: 0, scale: scaleJ,
            }, 0);

            tl.to(plR, {
              x: dR.x, y: dR.y,
              rotation: 0, scale: scaleR,
            }, 0.07);

            tl.to(preloader, {
              backgroundColor: "transparent",
              duration: 0.9,
              ease: "power2.out",
            }, 0.25);
          } catch (e) {
            console.error("Preloader error:", e);
            preloader.style.display = "none";
          }
        }, 500);
      });
    </script>
    <a href="#main-content" class="skip-link">{t.skipLink}</a>
    <main id="main-content">
      <slot />
    </main>
    <script>
      import Lenis from "lenis";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      if (!window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
        const isMobile = window.innerWidth < 768;
        if (!isMobile) {
          const lenis = new Lenis({
            duration: 1.2,
            easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            orientation: "vertical",
            smoothWheel: true,
          });

          lenis.on("scroll", () => ScrollTrigger.update());

          window.lenis = lenis;

          function raf(time) {
            lenis.raf(time);
            requestAnimationFrame(raf);
          }

          requestAnimationFrame(raf);
        }
      }
    </script>
    <script>
      const isMobileAnim = window.innerWidth < 768;
      const reducedMotionAnim = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!reducedMotionAnim && !isMobileAnim) {
        import("../scripts/animations.js");
      }
    </script>

    <script>
      (function () {
        if (window.innerWidth >= 768) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        const els = document.querySelectorAll("[data-reveal]");
        if (!els.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15 }
        );

        els.forEach((el) => observer.observe(el));
      })();
    </script>

    <button
      id="btn-top"
      class="fixed bottom-8 right-8 z-50 p-4 rounded-full bg-accent-orange text-white shadow-lg hover:shadow-xl transition-all duration-300 cursor-pointer border-none outline-none translate-y-20 opacity-0 pointer-events-none"
      aria-label={t.backToTop}
    >
      <svg
        id="arrow-top"
        class="w-5 h-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 19V5M12 5L5 12M12 5L19 12" />
      </svg>
    </button>

    <script>
      const btn = document.getElementById("btn-top");
      const arrow = document.getElementById("arrow-top");
      if (!btn || !arrow) throw new Error("Missing btn-top or arrow-top elements");

      window.addEventListener("scroll", () => {
        const y = window.scrollY;
        if (y > 400) {
          btn.classList.remove("translate-y-20", "opacity-0", "pointer-events-none");
          btn.classList.add("translate-y-0", "opacity-100");
        } else {
          btn.classList.remove("translate-y-0", "opacity-100");
          btn.classList.add("translate-y-20", "opacity-0", "pointer-events-none");
        }
      });

      btn.addEventListener("mouseenter", () => {
        arrow.style.transition = "transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1)";
        arrow.style.transform = "scaleY(0.6)";
      });

      btn.addEventListener("mouseleave", () => {
        arrow.style.transform = "scaleY(1)";
      });

      btn.addEventListener("click", (e) => {
        const rect = btn.getBoundingClientRect();
        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const colors = ["#FF5C2B", "#5B1FFF", "#FF7A4F", "#8A5CFF"];

        for (let i = 0; i < 24; i++) {
          const dot = document.createElement("span");
          const angle = (Math.PI * 2 * i) / 24;
          const dist = 60 + Math.random() * 80;
          const size = 3 + Math.random() * 5;
          const dx = Math.cos(angle) * dist;
          const dy = Math.sin(angle) * dist;
          dot.style.cssText = `
            position: fixed; left: ${cx}px; top: ${cy}px; z-index: 9999;
            width: ${size}px; height: ${size}px; border-radius: 50%;
            background: ${colors[i % colors.length]};
            pointer-events: none;
            transition: all 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
            opacity: 1;
          `;
          document.body.appendChild(dot);
          requestAnimationFrame(() => {
            dot.style.transform = `translate(${dx}px, ${dy}px) scale(0.3)`;
            dot.style.opacity = "0";
          });
          setTimeout(() => dot.remove(), 800);
        }

        btn.style.transition = "transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease";
        btn.style.transform = "translateY(-100px) scale(0.6)";
        btn.style.opacity = "0";
        setTimeout(() => {
          if (window.lenis) {
            window.lenis.scrollTo(0, { lock: true, force: true });
          } else {
            window.scrollTo({ top: 0, behavior: "smooth" });
          }
        }, 150);
        setTimeout(() => {
          btn.style.transition = "transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.5s ease";
          btn.style.transform = "translateY(0) scale(1)";
          btn.style.opacity = "1";
          arrow.style.transform = "scaleY(1)";
        }, 700);
      });
    </script>
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  :root {
    --bg-hex: #F2ECE4;
    --theme-dur: 0.6s;
    --dur-fast: 0.15s;
    --dur-base: 0.3s;
    --dur-slow: 0.5s;
    --clr-accent-orange: #FF5C2B;
    --clr-accent-purple: #5B1FFF;
    --clr-accent-pastel: #FFB088;
    --rgb-accent-orange: 255, 92, 43;
    --rgb-accent-purple: 91, 31, 255;
    --rgb-accent-pastel: 255, 176, 136;
  }

  :root.dark {
    --bg-hex: #1A1A1A;
  }

  body {
    background-color: var(--bg-hex);
    font-family: "Satoshi", sans-serif;
    color: #1A1613;
    line-height: 1.6;
    overflow-x: hidden;
    transition: background-color var(--theme-dur) ease, color var(--theme-dur) ease;
  }

  :root.dark body {
    color: #F0F0F0;
  }

  #main-nav.scrolled {
    transition: background-color 0.5s ease, box-shadow 0.5s ease;
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  [data-reveal]:not(.revealed) {
    opacity: 0;
    transform: translateY(30px);
  }

  .revealed {
    animation: fade-in-up 0.6s ease-out forwards;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "Clash Display", sans-serif;
    font-weight: 700;
  }

  ::selection {
    background-color: #FF5C2B;
    color: #fff;
  }

  :focus-visible {
    outline: 2px solid #FF5C2B;
    outline-offset: 3px;
    border-radius: 4px;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 16px;
    z-index: 9999;
    padding: 12px 24px;
    background: #FF5C2B;
    color: #fff;
    font-family: "Satoshi", sans-serif;
    font-size: 14px;
    font-weight: 500;
    border-radius: 8px;
    text-decoration: none;
    transition: top 0.2s ease;
  }

  .skip-link:focus {
    top: 16px;
  }

  #preloader {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background-color: var(--bg-hex);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }

    html {
      scroll-behavior: auto;
    }
  }
</style>
