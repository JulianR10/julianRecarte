---
import { ViewTransitions } from "astro:transitions";
import "@styles/globals.css";

interface Props {
  title?: string;
  description?: string;
  jobTitle?: string;
  lang?: string;
  t?: Record<string, string>;
}

const {
  title = "Julián Recarte | Creative Frontend Developer",
  description = "Convierto marcas en experiencias web interactivas.",
  jobTitle = "Creative Frontend Developer",
  lang = "es",
  t = { skipLink: "Ir al contenido principal", backToTop: "Volver arriba" },
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <ViewTransitions />
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/julianRecarte/favicon.svg" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/julianRecarte/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/julianRecarte/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/julianRecarte/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={`https://julianrecarte.github.io/julianRecarte/${lang}/`} />
    <meta property="og:image" content="https://julianrecarte.github.io/julianRecarte/og-image.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={description} />
    <meta property="og:locale" content={lang === "es" ? "es_ES" : lang === "en" ? "en_US" : "it_IT"} />
    <meta property="og:site_name" content="Julián Recarte" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://julianrecarte.github.io/julianRecarte/og-image.png" />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="es" href="https://julianrecarte.github.io/julianRecarte/es/" />
    <link rel="alternate" hreflang="en" href="https://julianrecarte.github.io/julianRecarte/en/" />
    <link rel="alternate" hreflang="it" href="https://julianrecarte.github.io/julianRecarte/it/" />
    <link rel="alternate" hreflang="x-default" href="https://julianrecarte.github.io/julianRecarte/" />
    <link rel="canonical" href={`https://julianrecarte.github.io/julianRecarte/${lang}/`} />

    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Julián Recarte",
      "image": "https://julianrecarte.github.io/julianRecarte/og-image.png",
      "jobTitle": jobTitle,
      description,
      "url": `https://julianrecarte.github.io/julianRecarte/${lang}/`,
      "sameAs": [
        "https://github.com/JulianR10",
        "https://instagram.com/julianrecarte.dev",
        "https://wa.me/393447817557"
      ],
      "knowsAbout": [
        "Frontend Development",
        "React",
        "Astro",
        "GSAP",
        "TailwindCSS",
        "Three.js",
        "TypeScript",
        "Framer Motion"
      ],
      "knowsLanguage": ["Spanish", "English", "Italian"]
    })}></script>

    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      rel="preload"
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap"
      as="style"
      crossorigin
    />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@400,500,700&display=swap"
      rel="stylesheet"
      crossorigin
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Mozilla+Headline:wdth,wght@75..125,100..900&display=swap"
      rel="stylesheet"
    />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem("dark-mode");
        if (stored === "true") {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
    <noscript><style>[data-reveal],[data-reveal-heading],[data-reveal-stagger]{opacity:1!important;transform:none!important}</style></noscript>
  </head>
  <body transition:animate="slide">
    <a href="#main-content" class="skip-link">{t.skipLink}</a>
    <div data-hero-orb class="hidden md:block fixed top-1/4 -left-32 w-96 h-96 rounded-full orb-accent blur-3xl pointer-events-none" style="will-change: transform"></div>
    <div data-hero-orb class="hidden md:block fixed -top-36 -right-20 w-72 h-72 rounded-full bg-accent-purple/10 blur-3xl pointer-events-none dark:bg-accent-purple/5 z-[60]" style="will-change: transform"></div>
    <header><slot name="nav" /></header>
    <slot name="hero" />
    <main id="main-content" class="w-full max-w-[100vw] overflow-x-clip">
      <slot />
    </main>
    <slot name="footer" />

    <script>
      import { initAll, destroyAll } from "@scripts/main";
      import { createLifecycle } from "@scripts/lifecycle";
      createLifecycle(initAll, destroyAll);
    </script>

    <script>
      let revealObserver = null;

      function initRevealObserver() {
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

        const els = document.querySelectorAll("[data-reveal], [data-reveal-heading], [data-reveal-stagger]");
        if (!els.length) return;

        const items = [];
        els.forEach((el) => {
          if (el.hasAttribute("data-reveal-stagger")) {
            items.push(...el.children);
          } else {
            items.push(el);
          }
        });

        revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("revealed");
                revealObserver.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.15 }
        );

        items.forEach((el) => revealObserver.observe(el));
      }

      function destroyRevealObserver() {
        if (revealObserver) { revealObserver.disconnect(); revealObserver = null; }
      }

      import { createLifecycle } from "@scripts/lifecycle";
      createLifecycle(initRevealObserver, destroyRevealObserver);
    </script>

    <button
      id="btn-top"
      class="fixed bottom-8 right-8 z-50 p-4 rounded-full bg-accent-orange text-white shadow-lg hover:shadow-xl transition-all duration-300 cursor-pointer border-none outline-none translate-y-20 opacity-0 pointer-events-none"
      aria-label={t.backToTop}
    >
      <svg
        id="arrow-top"
        class="w-5 h-5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 19V5M12 5L5 12M12 5L19 12" />
      </svg>
    </button>

    <script>
      import { initBackToTop, destroyBackToTop } from "@scripts/back-to-top";
      import { createLifecycle } from "@scripts/lifecycle";
      createLifecycle(initBackToTop, destroyBackToTop);
    </script>

  </body>
</html>
